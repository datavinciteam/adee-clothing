        <style>
          :host {
            width: 100%;
            /* Reserve content-sized height so the loading shimmer and the rendered
               coverage row occupy the same vertical space — avoids the layout shift
               (CLS) when loading swaps to content.
               --op-checkbox-host-measured-height is written at runtime by
               HostHeightReserveManager; --op-checkbox-host-min-height is the
               merchant-tunable floor. max() keeps the larger of the two so a
               theme override is honored without the inline measure clobbering it. */
            min-height: max(
              var(--op-checkbox-host-min-height, 0px),
              var(--op-checkbox-host-measured-height, 56px)
            );

            --op-primary-bg: ${e.primaryButton.backgroundColor||t.primaryBg};
            --op-primary-color: ${e.primaryButton.color||t.primaryColor};
            --op-secondary-bg: ${e.secondaryButton.backgroundColor||t.secondaryBg};
            --op-secondary-color: ${e.secondaryButton.color||t.secondaryColor};
            --op-secondary-border-width: ${e.secondaryButton.borderWidth||t.secondaryBorderWidth};
            --op-secondary-border-color: ${e.secondaryButton.borderColor||t.secondaryBorderColor};
            --op-shared-padding: ${e.buttonsShared.padding||t.sharedPadding};
            --op-shared-border-radius: ${e.buttonsShared.borderRadius||t.sharedBorderRadius};
            --op-primary-font-size: ${e.buttonsShared.fontSize||t.primaryFontSize};
            --op-secondary-font-size: ${e.buttonsShared.fontSize||t.secondaryFontSize};
          }

          /* Collapse the host itself so the stack's gap leaves no phantom slot. */
          :host([hide="true"]) {
            display: none !important;
          }

          .checkbox-row {
            display: flex;
            flex-direction: row;
            /* Pin the checkbox to the title line, not the title+caption center. */
            align-items: flex-start;
            gap: 12px;
            padding: 12px 0;
            border-top: 1px solid #B6BAC3;
            border-bottom: 1px solid #B6BAC3;
            background: none;
            font-family: var(--font-body-family, Helvetica, sans-serif);
          }

          .checkbox-row[data-hide="true"] {
            display: none;
          }

          .checkbox-input {
            width: 18px;
            height: 18px;
            /* 4px nudge aligns the input's optical center with the title cap-height (16px/21px). */
            margin: 4px 0 0 0;
            flex-shrink: 0;
            cursor: pointer;
            accent-color: var(--op-primary-bg);
          }

          .checkbox-input:disabled {
            opacity: 0.5;
            cursor: not-allowed;
          }

          /* In-flight toggle cue — row dims and cursor flips, without the bootstrap shimmer's full collapse. */
          :host([data-toggling="true"]) .checkbox-input {
            cursor: progress;
          }

          :host([data-toggling="true"]) .product-info {
            opacity: 0.7;
          }

          .product-info {
            display: flex;
            flex-direction: row;
            justify-content: space-between;
            /* Align the price with the title row (matches the button treatment). */
            align-items: flex-start;
            flex: 1 1 auto;
            gap: 16px;
            min-width: 0;
            transition: opacity 120ms ease;
          }

          .product-data {
            text-align: left;
            min-width: 0;
            flex: 1 1 auto;
          }

          .product-data p {
            margin: 0;
            text-align: left;
            line-height: 21px;
          }

          .product-title {
            font-weight: 600;
            font-size: 16px;
            display: inline-block;
          }

          .product-caption {
            font-weight: 400;
            font-size: 12px;
          }

          .info-icon {
            cursor: pointer;
            box-sizing: content-box;
            height: 16px;
            padding: 4px;
            margin: -4px -2px -4px -1px;
            opacity: 0.55;
            position: relative;
            top: 2px;
            display: inline-block;
          }

          .product-price {
            white-space: nowrap;
            font-weight: 600;
            font-size: 14px;
            /* Match .product-data p so the price baselines with the title row. */
            line-height: 21px;
          }

          .loading-container {
            display: none;
          }

          .loading-container.show {
            display: block;
          }

          .checkbox-row.hide {
            display: none;
          }

          .shimmer {
            background: linear-gradient(90deg, rgba(0,0,0,0.1) 25%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.1) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
          }

          .row-shimmer {
            display: block;
            width: 100%;
            height: 42px;
          }

          @keyframes shimmer {
            0% { background-position: -200% 0; }
            100% { background-position: 200% 0; }
          }
        </style>

        <div class="loading-container" part="loading-container">
          <span class="shimmer row-shimmer" part="row-shimmer"></span>
        </div>

        <div class="checkbox-row" part="container">
