        <style>
          :host {
            width: 100%;
            /* Reserve content-sized height so the loading shimmer and the rendered
               coverage UI occupy the same vertical space — avoids the layout shift
               (CLS) when loading swaps to content.
               --op-button-host-measured-height is written at runtime by
               HostHeightReserveManager; --op-button-host-min-height is the
               merchant-tunable floor. max() keeps the larger of the two so a
               theme override is honored without the inline measure clobbering it. */
            min-height: max(
              var(--op-button-host-min-height, 0px),
              var(--op-button-host-measured-height, 220px)
            );

            /* CSS Custom Properties for dynamic styling */
            --op-primary-bg: ${e.primaryButton.backgroundColor||t.primaryBg};
            --op-primary-color: ${e.primaryButton.color||t.primaryColor};
            --op-secondary-bg: ${e.secondaryButton.backgroundColor||t.secondaryBg};
            --op-secondary-color: ${e.secondaryButton.color||t.secondaryColor};
            --op-secondary-border-width: ${e.secondaryButton.borderWidth||t.secondaryBorderWidth};
            --op-secondary-border-color: ${e.secondaryButton.borderColor||t.secondaryBorderColor};
            --op-shared-padding: ${e.buttonsShared.padding||t.sharedPadding};
            --op-shared-border-radius: ${e.buttonsShared.borderRadius||t.sharedBorderRadius};
            --op-primary-font-size: ${e.buttonsShared.fontSize||t.primaryFontSize};
            --op-secondary-font-size: ${e.buttonsShared.fontSize||t.secondaryFontSize};
            --op-tag-bg: ${e.tag.backgroundColor||t.tagBg};
            --op-tag-color: ${e.tag.textColor||t.tagColor};
            --op-tag-border: ${e.tag.borderColor||t.tagBorder};
          }
          
          .dual-button-container {
            background: none;
          }

          .dual-button-container .custom-content {
            display: flex;
            flex-direction: column;
            gap: 1rem;
          }

          .dual-button-container[data-hide="true"] {
            display: none;
          }

          .loading-container {
            display: none;
          }

          .shimmer {
            background: linear-gradient(90deg, rgba(0,0,0,0.1) 25%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.1) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.5s infinite;
          }

          .text-shimmer {
            display: block;
            width: 100%;
            height: 18px;
            margin-bottom: 1rem;
          }

          .button-shimmer {
            display: block;
            width: 100%;
            height: 50px;
            margin-bottom: 1rem;
          }

          /*
           * Link presentation for the secondary action renders as short centered
           * text, not a full-height button — mirror that in the placeholder so the
           * shimmer doesn't over-reserve a button's worth of height for a link.
           */
          .button-shimmer--link {
            width: 50%;
            height: 21px;
            margin-left: auto;
            margin-right: auto;
          }

          @keyframes shimmer {
            0% {
              background-position: -200% 0;
            }
            100% {
              background-position: 200% 0;
            }
          }

          button {
            display: block;
            width: 100%;
            padding: 1rem 0 0;
            cursor: pointer;
            text-align: center;
          }

          button:disabled {
            opacity: 0.5;
            cursor: not-allowed;
          }

          button[data-loading="true"] {
            position: relative;
            color: transparent !important;
            pointer-events: none;
          }

          button[data-loading="true"]::after {
            content: "";
            position: absolute;
            width: 16px;
            height: 16px;
            top: 50%;
            left: 50%;
            margin-left: -8px;
            margin-top: -8px;
            border: 2px solid transparent;
            border-radius: 50%;
            border-top-color: currentColor;
            animation: button-loading-spinner 0.6s linear infinite;
            color: inherit;
          }

          @keyframes button-loading-spinner {
            0% {
              transform: rotate(0deg);
            }
            100% {
              transform: rotate(360deg);
            }
          }

          /* Primary button styles */
          button[data-variant="primary"] {
            display: flex;
            width: 100%;
            height: 50px;
            min-width: 93.6px;
            padding: var(--op-shared-padding);
            justify-content: center;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            background-color: var(--op-primary-bg);
            color: var(--op-primary-color);
            font-weight: 600;
            font-family: var(--font-body-family, Helvetica, sans-serif);
            border-radius: var(--op-shared-border-radius, var(--buttons-radius-outset, 0));
            border: 0;
            font-size: var(--op-primary-font-size);
            cursor: pointer;
          }

          /* Secondary button styles */
          button[data-variant="secondary"] {
            display: flex;
            width: 100%;
            height: 50px;
            min-width: 93.6px;
            padding: var(--op-shared-padding);
            justify-content: center;
            align-items: center;
            gap: 4px;
            flex-shrink: 0;
            color: var(--op-secondary-color);
            background-color: var(--op-secondary-bg);
            font-weight: 500;
            font-family: var(--font-body-family, Helvetica, sans-serif);
            border-radius: var(--op-shared-border-radius, var(--buttons-radius-outset, 0));
            border: var(--op-secondary-border-width) solid var(--op-secondary-border-color);
            font-size: var(--op-secondary-font-size);
            cursor: pointer;
          }

          /*
           * Link presentation for the secondary action. Renders as plain
           * underlined text using a fixed, theme-driven link color rather than
           * the configurable secondary button colors/border.
           */
          button[data-variant="link"] {
            display: block;
            width: 100%;
            padding: 0.5rem 0;
            background-color: transparent;
            border: 0;
            color: rgb(var(--color-link, 0,0,0));
            font-weight: 500;
            font-family: var(--font-body-family, Helvetica, sans-serif);
            font-size: var(--op-secondary-font-size);
            text-align: center;
            text-decoration: underline;
            cursor: pointer;
          }

          /* Outline button styles */
          button[data-variant="outline"] {
            background-color: transparent;
            color: #3b82f6;
            border: 1px solid #3b82f6;
          }

          button[data-variant="outline"]:hover:not(:disabled) {
            background-color: #3b82f6;
            color: white;
          }

          button[data-variant="outline"]:active:not(:disabled) {
            background-color: #2563eb;
            border-color: #2563eb;
          }

          /* Danger button styles */
          button[data-variant="danger"] {
            background-color: #ef4444;
            color: white;
          }

          button[data-variant="danger"]:hover:not(:disabled) {
            background-color: #dc2626;
          }

          button[data-variant="danger"]:active:not(:disabled) {
            background-color: #b91c1c;
          }

          /*
           * Title, info icon, and inline badge share one balanced line box so
           * the icon hugs the last word instead of orphaning. The icon flows as
           * inline content, so any slack sits after it rather than between it
           * and the title.
           */
          .product-title-line {
            display: inline-block;
            text-wrap: balance;
          }

          .product-title {
            font-weight: 600;
            font-size: 16px;
            display: inline;
          }

          .product-caption {
            font-weight: 400;
            font-size: 12px;
          }

          .info-icon {
            cursor: pointer;
            box-sizing: content-box;
            height: 16px;
            padding: 4px;
            margin: -4px -2px -4px -1px;
            opacity: 0.55;
            position: relative;
            top: 2px;
            display: inline-block;
          }

          .product-info {
            display: flex;
            flex-direction: column;
            gap: 2px;
            padding: 8px 0;
            border-top: 1px solid #B6BAC3;
            border-bottom: 1px solid #B6BAC3;
          }

          /*
           * Two-row grid: "Recommended" tag (col 2, row 1) stacks above title.
           * Thumbnail (col 1) sits on row 2 only, flanking the title row —
           * when the tag is visible, col 1 / row 1 is intentionally empty so
           * the tag is left-aligned with the title rather than the thumbnail.
           * Tag uses margin-bottom (not row-gap) so row 1 collapses when the
           * tag is hidden.
           *
           * column-gap: 0 — per-edge margins on .cart-thumbnail and
           * .product-price let the thumbnail-to-title gap differ from the
           * title-to-price gap.
           */
          .product-info-row {
            display: grid;
            grid-template-columns: auto 1fr auto;
            grid-template-rows: auto auto;
            column-gap: 0px;
          }

          .product-info p {
              margin: 0;
              text-align: left;
              line-height: 21px;
          }

          .product-data {
            text-align: left;
            grid-column: 2;
            grid-row: 2;
          }

          .recommended-tag {
            display: none;
            padding: 1px 4px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 600;
            line-height: 16px;
            letter-spacing: 0.02em;
            text-transform: none;
            color: var(--op-tag-color);
            background-color: var(--op-tag-bg);
            border: 1px solid var(--op-tag-border);
            font-family: var(--font-body-family, Helvetica, sans-serif);
          }

          .recommended-tag--block {
            grid-column: 2;
            grid-row: 1;
            justify-self: start;
            align-self: flex-start;
            margin-bottom: 4px;
          }

          .recommended-tag--inline {
            margin-left: 8px;
            position: relative;
            vertical-align: top;
            top: 3px;
          }

          /*
           * Placement is content-driven for every protection mode: default to
           * the inline slot next to the info icon, and only promote to the block
           * slot above the row when the badge can't fit on the title's first
           * line. data-tag-wrapped is set by RecommendedTagWrapManager in JS
           * (CSS can't detect a wrap); the measure runs inside requestAnimationFrame
           * before first paint, so long titles (e.g. combined mode) land above
           * without flashing inline.
           */
          :host([data-tag-enabled]) .recommended-tag--inline {
            display: inline-flex;
          }

          :host([data-tag-enabled][data-tag-wrapped]) .recommended-tag--inline {
            display: none;
          }

          :host([data-tag-enabled][data-tag-wrapped]) .recommended-tag--block {
            display: inline-flex;
          }

          .product-price {
            white-space: nowrap;
            grid-column: 3;
            grid-row: 2;
            align-self: start;
            margin-left: 16px;
          }

          .cart-thumbnail {
            display: none;
            width: 62px;
            height: 62px;
            flex-shrink: 0;
            border-radius: 4px;
            overflow: hidden;
            grid-column: 1;
            grid-row: 2;
            align-self: start;
            margin-right: 4px;
          }

          :host([data-thumbnail-type="default"]) .cart-thumbnail,
          :host([data-thumbnail-type="custom"]) .cart-thumbnail {
            display: inline-flex;
            align-items: center;
            justify-content: center;
          }

          :host([data-thumbnail-type="default"]) .cart-thumbnail__custom,
          :host([data-thumbnail-type="custom"]) .cart-thumbnail__default {
            display: none;
          }

          .cart-thumbnail__custom {
            width: 40px;
            height: 32px;
            background-image: var(--op-thumbnail-url);
            background-size: contain;
            background-position: center;
            background-repeat: no-repeat;
          }

          .cart-thumbnail__default svg {
            width: 40px;
            height: 32px;
          }

          .loop-hidden {
            display: none !important;
          }

          .show {
            display: block;
          }

          .hide {
            display: none;
          }
        </style>

        <div class="loading-container" part="loading-container">
          <div>
            <span class="shimmer text-shimmer" part="text-shimmer"></span>
            <span class="shimmer text-shimmer" part="text-shimmer"></span>
          </div>
          <div>
            <span class="shimmer button-shimmer" part="button-shimmer"></span>
            <span
              id="secondary-shimmer"
              class="shimmer button-shimmer${this.getSecondaryButtonVariant()===`link`?` button-shimmer--link`:``}"
              part="button-shimmer"
            ></span>
          </div>
        </div>

        <div class="dual-button-container" part="container">
          <div class="custom-content" part="content">
            <div class="product-info" part="product-info">
              <div class="product-info-row" part="product-info-row">
                <span class="cart-thumbnail" data-testid="cart-thumbnail" aria-hidden="true" part="thumbnail">
                  <span class="cart-thumbnail__default" part="thumbnail-default">${n}</span>
                  <span class="cart-thumbnail__custom" part="thumbnail-custom"></span>
                </span>
                <span
                  class="recommended-tag recommended-tag--block"
                  data-testid="recommended-tag-block"
                  part="tag tag-block"
                >Recommended</span>
                <div class="product-data" part="product-data">
                  <span class="product-title-line" part="product-title-line">
                    <p class="product-title" part="product-title">${this.getProductTitleText()}</p>
                    <img
                      id="info-icon-img"
                      class="info-icon"
                      alt="Learn more about ${this.getProductTitleText()}"
                      role="button"
                      tabindex="0"
                      aria-label="Learn more about ${this.getProductTitleText()}"
                      part="info-icon"
                    >
                    <span
                      class="recommended-tag recommended-tag--inline"
                      data-testid="recommended-tag-inline"
                      part="tag tag-inline"
                    >Recommended</span>
                  </span>
                  <p class="product-caption" part="product-caption">
                    <span part="product-caption-text">${this.getProductCaptionText()}</span>
                  </p>
                </div>
                <div class="product-price" id="price-label" aria-live="polite" part="price">
                   ${this.getPriceLabel()}
                </div>
              </div>
            </div>

            <button
              id="primary-button"
              data-original-text="${this.getPrimaryButtonText()}"
              data-variant="${this.getAttribute(`primary-variant`)||`primary`}"
              ${this.getAttribute(`disabled`)===`true`?`disabled`:``}
              part="primary-button">
              ${this.getPrimaryButtonText()}
            </button>
            <button
              id="secondary-button"
              data-variant="${this.getSecondaryButtonVariant()}"
              ${this.getAttribute(`disabled`)===`true`?`disabled`:``}
              part="secondary-button">
              ${this.getSecondaryButtonText()}
            </button>
          </div>
        </div>
      `,this.primaryButton=this.shadow.getElementById(`primary-button`),this.secondaryButton=this.shadow.getElementById(`secondary-button`),this.priceLabel=this.shadow.getElementById(`price-label`),this.cacheElementReferences(),this.updateInfoIcon()}cacheElementReferences(){this.cachedElements.titleElement=this.shadow.querySelector(`.product-title`),this.cachedElements.captionElement=this.shadow.querySelector(`.product-caption span`),this.cachedElements.infoIcon=this.shadow.querySelector(`.info-icon`),this.cachedElements.loadingContainer=this.shadow.querySelector(`.loading-container`),this.cachedElements.container=this.shadow.querySelector(`.dual-button-container`),this.cachedElements.secondaryShimmer=this.shadow.querySelector(`#secondary-shimmer`)}updateStylesOnly(){super.updateStylesOnly();let e=this.getSecondaryButtonVariant()===`link`;this.secondaryButton?.setAttribute(`data-variant`,this.getSecondaryButtonVariant()),this.cachedElements.secondaryShimmer?.classList.toggle(`button-shimmer--link`,e)}updateInfoIcon(){let e=this.shadow.getElementById(`info-icon-img`);if(e){let t=ti(`<svg width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg'>
