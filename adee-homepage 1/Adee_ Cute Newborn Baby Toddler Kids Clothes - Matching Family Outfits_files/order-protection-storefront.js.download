              <p class="product-title" part="product-title"><span class="product-title-text" part="product-title-text">${this.getProductTitleText()}</span><img id="info-icon-img" class="info-icon" alt="Learn more about ${this.escapeHtmlAttr(this.getProductTitleText())}" role="button" tabindex="0" aria-label="Learn more about ${this.escapeHtmlAttr(this.getProductTitleText())}" part="info-icon"></p>
              <p class="product-caption" part="product-caption"><span part="product-caption-text">${this.getProductCaptionText()}</span></p>
            </div>
            <div class="product-price" id="price-label" aria-live="polite" part="price">
              ${this.getPriceLabel()}
            </div>
          </div>
        </div>
