  .complex-text-italic {
    font-style: italic;
  }
  
  .complex-text-bold {
    font-weight: bold;
  }
  
  .complex-text-small {
    font-size: 0.875em;
  }
  
  .complex-text-medium {
    font-size: 1em;
  }
  
  .complex-text-large {
    font-size: 1.125em;
  }
  
  .complex-text-media-block {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin: 0 0 1em 0;
  }
  
  .complex-text-media-block:last-child {
    margin-bottom: 0;
  }
  
  .complex-text-media-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .complex-text-media-content {
    flex: 1;
    min-width: 0;
  }
  
  .complex-text-media-content p {
    margin: 0;
  }
